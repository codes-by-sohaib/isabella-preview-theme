{
  "components/custom/custom-js": "<!-- Custom JS for search dropdown header Start -->\n\n<script>\n(function () {\n  'use strict';\n\n  var wrapper  = document.querySelector('.cs-wrapper');\n  var input    = document.querySelector('.cs-input');\n  var clearBtn = document.querySelector('.cs-clear');\n  var dropdown = document.getElementById('cs-dropdown');\n\n  if (!input || !dropdown || !wrapper) return;\n\n  var TOKEN = wrapper.getAttribute('data-token') || '';\n  if (!TOKEN) { console.warn('CS Search: No storefront token.'); return; }\n\n  /* Stop words — inhe suggestions mein nahi dikhana */\n  var STOP = { 'in': 1, 'with': 1, 'and': 1, 'the': 1, 'a': 1, 'an': 1, 'of': 1, 'for': 1, 'to': 1, 'by': 1, 'from': 1 };\n\n  var GQL_QUERY = [\n    'query SearchProducts($term: String!) {',\n    '  site {',\n    '    search {',\n    '      searchProducts(filters: { searchTerm: $term }) {',\n    '        products {',\n    '          edges {',\n    '            node {',\n    '              name',\n    '              path',\n    '              sku',\n    '              customFields { edges { node { name value } } }',\n    '              defaultImage { url(width: 100) }',\n    '              prices {',\n    '                price { value currencyCode formatted }',\n    '                basePrice { value currencyCode formatted }',\n    '              }',\n    '            }',\n    '          }',\n    '          collectionInfo { totalItems }',\n    '        }',\n    '      }',\n    '    }',\n    '  }',\n    '}'\n  ].join('\\n');\n\n  /* State */\n  var timer      = null;\n  var cache      = Object.create(null);\n  var controller = null;\n  var activeIdx  = -1;\n  var items      = [];\n  var lastQuery  = '';\n\n  /* Events */\n  input.addEventListener('input', function () {\n    var q = input.value.trim();\n    clearBtn.hidden = q.length === 0;\n    onType(q);\n  });\n\n  clearBtn.addEventListener('click', function () {\n    input.value = '';\n    clearBtn.hidden = true;\n    input.focus();\n    closeDropdown();\n  });\n\n  document.addEventListener('click', function (e) {\n    if (!wrapper.contains(e.target)) closeDropdown();\n  });\n\n  input.addEventListener('keydown', function (e) {\n    if (!dropdown.classList.contains('cs-open')) return;\n    switch (e.key) {\n      case 'ArrowDown': e.preventDefault(); moveActive(1);  break;\n      case 'ArrowUp':   e.preventDefault(); moveActive(-1); break;\n      case 'Escape':    closeDropdown(); input.blur();       break;\n      case 'Enter':\n        if (activeIdx >= 0 && items[activeIdx]) {\n          e.preventDefault();\n          items[activeIdx].click();\n        }\n        break;\n    }\n  });\n\n  /* Type handler */\n  function onType(query) {\n    clearTimeout(timer);\n    if (!query || query.length < 2) { closeDropdown(); lastQuery = ''; return; }\n    if (query === lastQuery) return;\n    showSkeleton();\n    timer = setTimeout(function () {\n      lastQuery = query;\n      if (cache[query]) { render(query, cache[query]); return; }\n      fetchData(query);\n    }, 180);\n  }\n\n  /* GraphQL fetch */\n  function fetchData(query) {\n    if (controller) controller.abort();\n    controller = new AbortController();\n\n    fetch('/graphql', {\n      method: 'POST',\n      signal: controller.signal,\n      headers: {\n        'Content-Type': 'application/json',\n        'Authorization': 'Bearer ' + TOKEN,\n        'X-Requested-With': 'XMLHttpRequest'\n      },\n      body: JSON.stringify({ query: GQL_QUERY, variables: { term: query } })\n    })\n    .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })\n    .then(function (json) {\n      if (json.errors) { console.error('GQL errors:', json.errors); renderEmpty(); return; }\n\n      var result   = json.data.site.search.searchProducts.products;\n      /* Filter out products with status: extinct custom field */\n      var products = (result.edges || []).map(function (e) { return e.node; }).filter(function (p) {\n        var fields = p.customFields && p.customFields.edges ? p.customFields.edges : [];\n        return !fields.some(function (f) {\n          return f.node.name.toLowerCase() === 'status' && f.node.value.toLowerCase() === 'extinct';\n        });\n      });\n      var total    = (result.collectionInfo && result.collectionInfo.totalItems) || products.length;\n\n      /* Generate keyword suggestions from product names */\n      var suggestions = buildSuggestions(products, query);\n\n      cache[query] = { products: products, total: total, suggestions: suggestions };\n      render(query, cache[query]);\n    })\n    .catch(function (err) {\n      if (err.name !== 'AbortError') { console.error('CS Search error:', err); renderEmpty(); }\n    });\n  }\n\n  /* Build keyword suggestions from product names */\n  function buildSuggestions(products, query) {\n    var q       = query.toLowerCase();\n    var seen    = Object.create(null);\n    var results = [];\n\n    products.forEach(function (p) {\n      /* Full product name as suggestion if it matches */\n      var nameLower = p.name.toLowerCase();\n      if (nameLower.indexOf(q) > -1 && !seen[nameLower]) {\n        seen[nameLower] = 1;\n        results.push(p.name);\n      }\n\n      /* Individual meaningful words from product name */\n      var words = p.name.split(/[\\s\\(\\)\\-\\/,]+/);\n      words.forEach(function (word) {\n        var wl = word.toLowerCase();\n        if (wl.length < 3 || STOP[wl] || !wl.startsWith(q)) return;\n        /* Capitalize first letter */\n        var display = word.charAt(0).toUpperCase() + word.slice(1);\n        if (!seen[wl]) {\n          seen[wl] = 1;\n          results.push(display);\n        }\n      });\n    });\n\n    /* Sort: shorter matches first (more relevant) */\n    results.sort(function (a, b) { return a.length - b.length; });\n\n    return results.slice(0, 4);\n  }\n\n  /* Helpers */\n  function esc(s) {\n    return String(s)\n      .replace(/&/g, '&amp;')\n      .replace(/</g, '&lt;')\n      .replace(/>/g, '&gt;')\n      .replace(/\"/g, '&quot;');\n  }\n\n  function highlight(text, query) {\n    var idx = text.toLowerCase().indexOf(query.toLowerCase());\n    if (idx < 0) return esc(text);\n    return esc(text.slice(0, idx)) +\n      '<em class=\"cs-em\">' + esc(text.slice(idx, idx + query.length)) + '</em>' +\n      esc(text.slice(idx + query.length));\n  }\n\n  function getPrice(prices) {\n    if (!prices || !prices.price) return '';\n    return prices.price.formatted || '';\n  }\n\n  function getOldPrice(prices) {\n    if (!prices || !prices.basePrice || !prices.price) return '';\n    if (parseFloat(prices.basePrice.value) <= parseFloat(prices.price.value)) return '';\n    return prices.basePrice.formatted || '';\n  }\n\n  /* Render */\n  function render(query, data) {\n    activeIdx = -1;\n    var products    = data.products    || [];\n    var total       = data.total       || products.length;\n    var suggestions = data.suggestions || [];\n\n    if (!products.length && !suggestions.length) { renderEmpty(); return; }\n\n    var html = '';\n\n    /* Suggestions section */\n    if (suggestions.length) {\n      html += '<div class=\"cs-label\">Suggestions</div>';\n      html += '<ul class=\"cs-sugg\" role=\"group\">';\n      suggestions.forEach(function (s) {\n        html +=\n          '<li class=\"cs-sugg-item\" role=\"option\" tabindex=\"-1\" data-href=\"/search.php?search_query=' + encodeURIComponent(s) + '\">' +\n            '<svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\">' +\n              '<circle cx=\"11\" cy=\"11\" r=\"8\"/><path d=\"m21 21-4.35-4.35\"/>' +\n            '</svg>' +\n            highlight(s, query) +\n          '</li>';\n      });\n      html += '</ul>';\n    }\n\n    /* Products section */\n    if (products.length) {\n      html += '<a class=\"cs-label cs-label-link\" href=\"/search.php?search_query=' + encodeURIComponent(query) + '\">' + total.toLocaleString() + ' results for &ldquo;' + esc(query) + '&rdquo;</a>';\n      html += '<div class=\"cs-products\" role=\"group\">';\n\n      products.slice(0, 4).forEach(function (p) {\n        var img      = p.defaultImage ? p.defaultImage.url : '';\n        var price    = getPrice(p.prices);\n        var oldPrice = getOldPrice(p.prices);\n\n        html +=\n          '<a class=\"cs-card\" href=\"' + esc(p.path || '#') + '\" role=\"option\" tabindex=\"-1\">' +\n            '<div class=\"cs-thumb\">' +\n              (img\n                ? '<img src=\"' + esc(img) + '\" alt=\"' + esc(p.name) + '\" loading=\"lazy\">'\n                : '<div class=\"cs-thumb-ph\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"1\"/><path d=\"m3 16 5-5 4 4 3-3 6 6\"/></svg></div>'\n              ) +\n            '</div>' +\n            '<div class=\"cs-info\">' +\n              '<div class=\"cs-name\">' + esc(p.name) + '</div>' +\n              (p.sku ? '<div class=\"cs-sku\">' + esc(p.sku) + '</div>' : '') +\n              '<div>' +\n                (price ? '<span class=\"cs-price\">' + esc(price) + '</span>' : '') +\n                (oldPrice ? '<span class=\"cs-price-old\">' + esc(oldPrice) + '</span>' : '') +\n              '</div>' +\n            '</div>' +\n            '<svg class=\"cs-arrow\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\">' +\n              '<path d=\"M5 12h14M12 5l7 7-7 7\"/>' +\n            '</svg>' +\n          '</a>';\n      });\n\n      html += '</div>';\n    }\n\n    /* Footer */\n    html +=\n      '<div class=\"cs-footer\">' +\n        '<a class=\"cs-browse\" href=\"/search.php?search_query=' + encodeURIComponent(query) + '\">' +\n          'View All Results ' +\n          '<svg width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M5 12h14M12 5l7 7-7 7\"/></svg>' +\n        '</a>' +\n      '</div>';\n\n    dropdown.innerHTML = html;\n    openDropdown();\n    bindItems();\n  }\n\n  /* Skeleton */\n  function showSkeleton() {\n    var html = '<div class=\"cs-label\">Searching...</div><div class=\"cs-products\">';\n    for (var i = 0; i < 3; i++) {\n      html +=\n        '<div class=\"cs-skel-card\">' +\n          '<div class=\"cs-skel cs-skel-thumb\"></div>' +\n          '<div class=\"cs-skel-body\">' +\n            '<div class=\"cs-skel cs-skel-l1\"></div>' +\n            '<div class=\"cs-skel cs-skel-l2\"></div>' +\n            '<div class=\"cs-skel cs-skel-l3\"></div>' +\n          '</div>' +\n        '</div>';\n    }\n    dropdown.innerHTML = html + '</div>';\n    openDropdown();\n    items = [];\n  }\n\n  /* Empty */\n  function renderEmpty() {\n    dropdown.innerHTML = '<div class=\"cs-empty\">No products found</div>';\n    openDropdown();\n    items = [];\n  }\n\n  /* Bind items */\n  function bindItems() {\n    items = Array.from(dropdown.querySelectorAll('.cs-sugg-item, .cs-card'));\n    items.forEach(function (el, i) {\n      el.addEventListener('click', function (e) {\n        e.preventDefault();\n        var href = el.href || el.getAttribute('data-href');\n        if (href) window.location.href = href;\n      });\n      el.addEventListener('mouseenter', function () {\n        activeIdx = i;\n        items.forEach(function (e, j) { e.classList.toggle('cs-active', j === i); });\n      });\n    });\n  }\n\n  /* Keyboard move */\n  function moveActive(dir) {\n    if (!items.length) return;\n    activeIdx = Math.max(-1, Math.min(items.length - 1, activeIdx + dir));\n    items.forEach(function (el, i) { el.classList.toggle('cs-active', i === activeIdx); });\n    if (activeIdx >= 0) items[activeIdx].scrollIntoView({ block: 'nearest' });\n  }\n\n  function openDropdown() {\n    dropdown.classList.add('cs-open');\n    input.setAttribute('aria-expanded', 'true');\n  }\n\n  function closeDropdown() {\n    dropdown.classList.remove('cs-open');\n    input.setAttribute('aria-expanded', 'false');\n    activeIdx = -1;\n    items     = [];\n    lastQuery = '';\n  }\n\n})();\n</script>\n\n\n\n<!-- Custom JS for search dropdown header End -->"
}