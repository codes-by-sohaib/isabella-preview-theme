{
  "components/faceted-search/show-more-facets": "<div class=\"facetedSearch-inlineMore\">\r\n    <div class=\"form-field facetedSearch-inlineSearch\">\r\n        <input\r\n            class=\"form-input\"\r\n            type=\"search\"\r\n            placeholder=\"{{#if facet_title}}Enter {{facet_title}}...{{else}}Enter {{all_facets}}...{{/if}}\"\r\n            aria-label=\"{{#if facet_title}}Search {{facet_title}}{{else}}Search {{all_facets}}{{/if}}\">\r\n    </div>\r\n\r\n    <ul class=\"navList facetedSearch-inlineList\">\r\n        {{#each facets}}\r\n            {{#if facet '===' ../all_facets}}\r\n                {{#each items}}\r\n                    <li class=\"navList-item\">\r\n                        <a\r\n                            href=\"{{url}}\"\r\n                            class=\"navList-action navList-action--checkbox{{#if selected}} is-selected{{/if}}\"\r\n                            rel=\"nofollow\"\r\n                            data-faceted-search-facet>\r\n                            {{{sanitize title}}}\r\n\r\n                            {{#if ../show_product_counts}}\r\n                                {{#if count}}\r\n                                    <span>({{count}})</span>\r\n                                {{/if}}\r\n                            {{/if}}\r\n\r\n                            <span class=\"navList-action-close\" aria-hidden=\"true\">\r\n                                <svg class=\"icon\">\r\n                                    <use href=\"#icon-close\"/>\r\n                                </svg>\r\n                            </span>\r\n                        </a>\r\n                    </li>\r\n                {{/each}}\r\n            {{/if}}\r\n        {{/each}}\r\n    </ul>\r\n</div>\n"
}