{
  "components/common/header": "<a href=\"#main-content\" class=\"skip-to-main-link\">{{lang 'header.skip_to_main'}}</a>\n{{#if banners.top}}\n<div class=\"banners\" data-banner-location=\"top\">\n    {{#each (limit banners.top_metadata 1)}}\n    <div class=\"banner\" data-event-type=\"promotion\" data-entity-id=\"{{this.id}}\" data-name=\"{{this.banner-name}}\" data-position=\"{{this.location}}\" data-banner-id=\"{{this.banner-name}}\">\n        <div data-event-type=\"promotion-click\">\n            {{{this.content}}}\n        </div>\n    </div>\n    {{/each}}\n</div>\n{{/if}}\n<header class=\"header{{#if theme_settings.epic-sitewide-message}} header--epic-sitewide{{/if}}{{#if theme_settings.epic-toggle-sticky-header}} header-sticky{{/if}}\" role=\"banner\">\n    {{#if theme_settings.epic-sitewide-message}}\n        {{{region name=\"epic_sitewide_message--global\"}}}\n    {{/if}}\n    <div class=\"container\">\n        <a href=\"#\" class=\"mobileMenu-toggle\" data-mobile-menu-toggle=\"menu\">\n            <span class=\"mobileMenu-toggleIcon\">Toggle menu</span>\n        </a>\n\n        {{#if page_type '===' 'default'}}\n            <h1 class=\"header-logo header-logo--left\">\n                {{> components/common/store-logo}}\n            </h1>\n        {{else}}\n            <div class=\"header-logo header-logo--left\">\n                {{> components/common/store-logo}}\n            </div>\n        {{/if}}\n\n        {{#if theme_settings.epic-toggle-search}}\n            <div class=\"header-search\" data-epic-search>\n                {{> components/common/quick-search name='nav-quick-search'}}\n            </div>\n        {{/if}}\n\n        {{> components/common/navigation}}\n\n    </div>\n    <div class=\"navPages-wrap\">\n      <div class=\"container\">\n        <div class=\"navPages-container navPages-container--{{theme_settings.epic-align-navigation}}\" id=\"menu\" data-menu>\n          {{> components/common/navigation-menu}}\n        </div>\n      </div>\n    </div>\n</header>\n{{{region name=\"header_bottom--global\"}}}\n{{{region name=\"header_bottom\"}}}\n",
  "components/common/quick-search": "\r\n\r\n<div class=\"cs-wrapper\" data-token=\"{{settings.storefront_api.token}}\">\r\n  <form class=\"cs-form\" action=\"/search.php\" method=\"get\" role=\"search\">\r\n    <div class=\"cs-field\">\r\n      <svg class=\"cs-icon-search\" width=\"17\" height=\"17\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\">\r\n        <circle cx=\"11\" cy=\"11\" r=\"8\"/><path d=\"m21 21-4.35-4.35\"/>\r\n      </svg>\r\n      <input\r\n        class=\"cs-input\"\r\n        name=\"search_query\"\r\n        type=\"text\"\r\n        placeholder=\"Search products...\"\r\n        autocomplete=\"off\"\r\n        spellcheck=\"false\"\r\n        aria-label=\"Search products\"\r\n        aria-autocomplete=\"list\"\r\n        aria-controls=\"cs-dropdown\"\r\n        aria-expanded=\"false\"\r\n      />\r\n      <button class=\"cs-clear\" type=\"button\" aria-label=\"Clear search\" hidden>\r\n        <svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\r\n          <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/>\r\n          <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/>\r\n        </svg>\r\n      </button>\r\n    </div>\r\n    <div class=\"cs-dropdown\" id=\"cs-dropdown\" role=\"listbox\" aria-label=\"Search results\"></div>\r\n  </form>\r\n</div>\r\n\r\n<style>\r\n.cs-wrapper *, .cs-wrapper *::before, .cs-wrapper *::after {\r\n  box-sizing: border-box; margin: 0; padding: 0;\r\n}\r\n.cs-wrapper {\r\n  position: relative;\r\n  width: 100%;\r\n  font-family: 'Montserrat', 'Helvetica Neue', Arial, sans-serif;\r\n}\r\n.cs-input:focus {\r\n    border: none !important;\r\n    outline: none !important;\r\n}\r\n\r\n\r\n.cs-form { position: relative; width: 100%; }\r\n\r\n.cs-field {\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 10px;\r\n    background: #ffffff;\r\n    border: 1px solid #d2d2d2;\r\n    padding: 0 14px;\r\n    height: 48px;\r\n    transition: none;\r\n}\r\n.cs-field:focus-within {\r\n  border-color: #2d5a3d;\r\n  border-bottom-color: #2d5a3d;\r\n  box-shadow: 0 2px 0 #2d5a3d;\r\n}\r\n.cs-icon-search { color: #c0bbb5; flex-shrink: 0; transition: color 150ms ease; }\r\n.cs-field:focus-within .cs-icon-search { color: #2d5a3d; }\r\n.cs-input {\r\n  flex: 1;\r\n  border: none;\r\n  outline: none;\r\n  background: transparent;\r\n  font-family: inherit;\r\n  font-size: 13px;\r\n  font-weight: 400;\r\n  letter-spacing: 0.04em;\r\n  color: #1a1a1a;\r\n  caret-color: #2d5a3d;\r\n  min-width: 0;\r\n}\r\n.cs-input::placeholder { color: #c0bbb5; font-weight: 300; }\r\n.cs-clear {\r\n  background: none;\r\n  border: none;\r\n  cursor: pointer;\r\n  padding: 4px;\r\n  color: #c0bbb5;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  flex-shrink: 0;\r\n  transition: color 120ms ease;\r\n}\r\n.cs-clear:hover { color: #1a1a1a; }\r\n\r\n/* Dropdown */\r\n.cs-dropdown {\r\n  position: absolute;\r\n  top: calc(100% + 3px);\r\n  left: 0; right: 0;\r\n  background: #ffffff;\r\n  border: 1px solid #e2ddd8;\r\n  box-shadow: 0 12px 40px rgba(0,0,0,0.10), 0 2px 8px rgba(0,0,0,0.06);\r\n  opacity: 0;\r\n  transform: translateY(-5px);\r\n  pointer-events: none;\r\n  transition: opacity 160ms ease, transform 160ms ease;\r\n  max-height: 520px;\r\n  overflow-y: auto;\r\n  overflow-x: hidden;\r\n  z-index: 9999;\r\n  scrollbar-width: thin;\r\n  scrollbar-color: #e2ddd8 transparent;\r\n}\r\n.cs-dropdown.cs-open {\r\n  opacity: 1;\r\n  transform: translateY(0);\r\n  pointer-events: all;\r\n}\r\n\r\n/* Label */\r\n.cs-label {\r\n  font-size: 9px;\r\n  font-weight: 600;\r\n  letter-spacing: 0.2em;\r\n  text-transform: uppercase;\r\n  color: #2d5a3d;\r\n  padding: 13px 16px 7px;\r\n  border-bottom: 1px solid #f0ece7;\r\n  background: #fafaf9;\r\n  display: block;\r\n  text-decoration: none;\r\n}\r\n.cs-label-link {\r\n  cursor: pointer;\r\n  transition: background 100ms ease, color 100ms ease;\r\n}\r\n.cs-label-link:hover {\r\n  background: #f0ece7;\r\n  color: #1a4d2e;\r\n}\r\n\r\n/* Suggestions */\r\n.cs-sugg {\r\n  list-style: none;\r\n  padding: 4px 0;\r\n  border-bottom: 1px solid #f0ece7;\r\n}\r\n.cs-sugg-item {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 10px;\r\n  padding: 8px 16px;\r\n  font-size: 12.5px;\r\n  font-weight: 400;\r\n  letter-spacing: 0.02em;\r\n  color: #2a2a2a;\r\n  cursor: pointer;\r\n  transition: background 100ms ease;\r\n  user-select: none;\r\n}\r\n.cs-sugg-item:hover, .cs-sugg-item.cs-active { background: #f5f2ee; }\r\n.cs-sugg-item svg { color: #c0bbb5; flex-shrink: 0; }\r\n.cs-em { font-style: normal; color: #2d5a3d; font-weight: 600; }\r\n\r\n/* Cards */\r\n.cs-products { padding: 4px 0; }\r\n.cs-card {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n  padding: 8px 16px;\r\n  text-decoration: none;\r\n  color: inherit;\r\n  cursor: pointer;\r\n  transition: background 100ms ease;\r\n}\r\n.cs-card:hover, .cs-card.cs-active { background: #f5f2ee; }\r\n.cs-thumb {\r\n  width: 48px; height: 60px;\r\n  flex-shrink: 0;\r\n  overflow: hidden;\r\n  background: #f0ece7;\r\n}\r\n.cs-thumb img {\r\n  width: 100%; height: 100%;\r\n  object-fit: cover;\r\n  display: block;\r\n  transition: transform 200ms ease;\r\n}\r\n.cs-card:hover .cs-thumb img { transform: scale(1.04); }\r\n.cs-thumb-ph {\r\n  width: 100%; height: 100%;\r\n  background: linear-gradient(145deg, #ede9e3, #ddd8d0);\r\n  display: flex; align-items: center; justify-content: center;\r\n}\r\n.cs-thumb-ph svg { color: #c8c2b8; opacity: 0.6; }\r\n.cs-info { flex: 1; min-width: 0; }\r\n.cs-name {\r\n  font-size: 10.5px;\r\n  font-weight: 600;\r\n  letter-spacing: 0.08em;\r\n  text-transform: uppercase;\r\n  color: #1a1a1a;\r\n  white-space: nowrap;\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n  margin-bottom: 3px;\r\n}\r\n.cs-sku { font-size: 10px; color: #b0aba5; margin-bottom: 4px; }\r\n.cs-price { font-size: 13px; font-weight: 500; color: #2d5a3d; }\r\n.cs-price-old { font-size: 11px; color: #b0aba5; text-decoration: line-through; margin-left: 5px; }\r\n.cs-arrow { color: #ddd8d2; flex-shrink: 0; transition: color 120ms ease, transform 120ms ease; }\r\n.cs-card:hover .cs-arrow { color: #2d5a3d; transform: translateX(3px); }\r\n\r\n/* Footer */\r\n.cs-footer {\r\n  border-top: 1px solid #f0ece7;\r\n  padding: 11px 16px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  background: #fafaf9;\r\n}\r\n.cs-count { font-size: 10.5px; color: #b0aba5; }\r\n.cs-browse {\r\n  font-size: 9.5px;\r\n  font-weight: 600;\r\n  letter-spacing: 0.14em;\r\n  text-transform: uppercase;\r\n  color: #2d5a3d;\r\n  text-decoration: none;\r\n  display: flex; align-items: center; gap: 5px;\r\n  transition: gap 120ms ease;\r\n}\r\n.cs-browse:hover { gap: 9px; }\r\n\r\n/* Empty */\r\n.cs-empty {\r\n  padding: 30px 16px;\r\n  text-align: center;\r\n  font-size: 12.5px;\r\n  color: #b0aba5;\r\n}\r\n\r\n/* Skeleton */\r\n.cs-skel-card { display: flex; align-items: center; gap: 12px; padding: 8px 16px; }\r\n.cs-skel {\r\n  background: linear-gradient(90deg, #f0ece7 25%, #e8e3dd 50%, #f0ece7 75%);\r\n  background-size: 200% 100%;\r\n  animation: cs-shimmer 1.4s ease-in-out infinite;\r\n  border-radius: 1px;\r\n}\r\n@keyframes cs-shimmer {\r\n  0%   { background-position: 200% 0; }\r\n  100% { background-position: -200% 0; }\r\n}\r\n.cs-skel-thumb { width: 48px; height: 60px; flex-shrink: 0; }\r\n.cs-skel-body  { flex: 1; }\r\n.cs-skel-l1 { height: 9px;  width: 70%; margin-bottom: 8px; }\r\n.cs-skel-l2 { height: 8px;  width: 38%; margin-bottom: 8px; }\r\n.cs-skel-l3 { height: 10px; width: 24%; }\r\n\r\n\r\n\r\n@media (min-width: 768px) {\r\n    .cs-wrapper {\r\n    position: relative;\r\n    width: 80% !important;\r\n    margin: 0 auto;\r\n}\r\n}\r\n\r\n</style>\r\n\r\n",
  "components/common/store-logo": "<a href=\"{{urls.home}}\" class=\"header-logo__link\" data-header-logo-link>\n    {{#if settings.store_logo.image}}\n        {{#if theme_settings.logo_size '===' 'original'}}\n        <img class=\"header-logo-image-unknown-size\"\n             src=\"{{getImage settings.store_logo.image 'logo_size'}}\"\n             alt=\"{{settings.store_logo.title}}\"\n             title=\"{{settings.store_logo.title}}\">\n        {{else}}\n        <div class=\"header-logo-image-container\">\n            <img class=\"header-logo-image\"\n                 src=\"{{getImage settings.store_logo.image 'logo_size'}}\"\n                 srcset=\"{{getImageSrcset1x2x settings.store_logo.image theme_settings.logo_size}}\"\n                 alt=\"{{settings.store_logo.title}}\"\n                 title=\"{{settings.store_logo.title}}\">\n        </div>\n        {{/if}}\n      <span class=\"u-hiddenVisually\">{{settings.store_logo.title}}</span>\n    {{else}}\n    <span class=\"header-logo-text\">{{settings.store_logo.title}}</span>\n    {{/if}}\n</a>\n",
  "components/common/navigation": "<nav class=\"navUser\">\n    {{#if theme_settings.show_channels}}\n        {{> components/common/channel-selector}}\n    {{/if}}\n\n    <ul class=\"navUser-section navUser-section--alt\">\n        {{#if customer.store_credit.value '>' 0}}\n            <li class=\"navUser-item\">\n                <a class=\"navUser-action navUser-action--storeCredit\"\n                   data-dropdown=\"storeCredit-dropdown\"\n                   data-options=\"align:bottom\"\n                   href=\"{{urls.cart}}\"\n                   aria-label=\"{{lang 'common.store_credit_overview' credit=customer.store_credit.formatted}}\"\n                >\n                    <span class=\"navUser-action-divider\">\n                        {{lang 'common.store_credit_overview' credit=customer.store_credit.formatted}}\n                    </span>\n                </a>\n                <div class=\"dropdown-menu\" id=\"storeCredit-dropdown\" data-dropdown-content aria-hidden=\"true\">\n                    {{{lang 'common.store_credit' store_credit=customer.store_credit.formatted}}}\n                </div>\n            </li>\n        {{/if}}\n        <li class=\"navUser-item\">\n            <a class=\"navUser-action navUser-item--compare\"\n               href=\"{{urls.compare}}\"\n               data-compare-nav\n               aria-label=\"{{lang 'common.compare'}}\"\n            >\n                {{lang 'common.compare'}} <span class=\"countPill countPill--positive countPill--alt\"></span>\n            </a>\n        </li>\n        {{#unless theme_settings.epic-toggle-search}}\n            <li class=\"navUser-item\">\n                <button class=\"navUser-action navUser-action--quickSearch\"\n                type=\"button\"\n                id=\"quick-search-expand\"\n                data-search=\"quickSearch\"\n                aria-controls=\"quickSearch\"\n                aria-label=\"{{lang 'common.search'}}\"\n                >\n                    {{lang 'common.search'}}\n                </button>\n            </li>\n        {{/unless}}\n        {{#if settings.gift_certificates_enabled}}\n            <li class=\"navUser-item\">\n                <a class=\"navUser-action\"\n                   href=\"{{urls.gift_certificate.purchase}}\"\n                   aria-label=\"{{lang 'common.gift_cert'}}\"\n                >\n                    <i class=\"icon\" aria-hidden=\"true\">\n                        <svg>\n                            <use href=\"#icon-epic-gift\"></use>\n                        </svg>\n                    </i>\n                    {{#if theme_settings.epic-show-header-icon-labels}}\n                      {{lang 'common.gift_cert'}}\n                    {{/if}}\n                </a>\n            </li>\n        {{/if}}\n        <li class=\"navUser-item navUser-item--account\">\n            <a class=\"navUser-action\"\n                {{#if customer}}\n                href=\"{{urls.account.index}}\"\n                aria-label=\"{{lang 'common.account'}}\"\n                {{else}}\n                href=\"{{urls.auth.login}}\"\n                aria-label=\"{{lang 'common.login'}}\"\n                {{/if}}\n            >\n                <i class=\"icon\" aria-hidden=\"true\">\n                    <svg>\n                        <use href=\"#icon-epic-user\"></use>\n                    </svg>\n                </i>\n                {{#if theme_settings.epic-show-header-icon-labels}}\n                  {{#if customer}}\n                  {{lang 'common.account'}}\n                  {{else}}\n                  {{lang 'common.login'}}\n                  {{/if}}\n                {{/if}}\n            </a>\n            {{#if settings.account_creation_enabled}}\n              {{#if theme_settings.epic-show-header-icon-labels}}\n                {{#unless customer}}\n                    <span class=\"navUser-or\">{{lang 'common.or'}}</span>\n                    <a class=\"navUser-action\"\n                        href=\"{{urls.auth.create_account}}\"\n                        aria-label=\"{{lang 'common.sign_up'}}\"\n                    >\n                        {{lang 'common.sign_up'}}\n                    </a>\n                {{/unless}}\n              {{/if}}\n            {{/if}}\n        </li>\n        {{#or customer (unless settings.hide_price_from_guests)}}\n            {{#gt (length currency_selector.currencies) 1}}\n                <li class=\"navUser-item navUser-item--currency \">\n                    {{> components/common/currency-selector}}\n                </li>\n            {{/gt}}\n        {{/or}}\n        <li class=\"navUser-item navUser-item--cart\">\n            <a class=\"navUser-action\"\n               data-cart-preview\n               data-dropdown=\"cart-preview-dropdown\"\n               data-options=\"align:right\"\n               href=\"{{urls.cart}}\"\n               aria-label=\"{{lang 'cart.nav_aria_label'}}\"\n            >\n                <i class=\"icon\" aria-hidden=\"true\">\n                    <svg>\n                        <use href=\"#icon-epic-bag\"></use>\n                    </svg>\n                </i>\n                {{#if theme_settings.epic-show-header-icon-labels}}\n                  <span class=\"navUser-item-cartLabel\">{{lang 'common.cart'}}</span>\n                {{/if}}\n                <span class=\"countPill cart-quantity\"></span>\n            </a>\n\n            <div class=\"dropdown-menu\" id=\"cart-preview-dropdown\" data-dropdown-content aria-hidden=\"true\"></div>\n        </li>\n    </ul>\n    {{#unless theme_settings.epic-toggle-search}}\n        <div class=\"dropdown dropdown--quickSearch\" id=\"quickSearch\" aria-hidden=\"true\" data-prevent-quick-search-close>\n            {{> components/common/quick-search name='nav-quick-search'}}\n        </div>\n    {{/unless}}\n</nav>\n",
  "components/common/navigation-menu": "<nav class=\"navPages\">\n    {{#unless theme_settings.epic-toggle-search}}\n        <div class=\"navPages-quickSearch\">\n            {{> components/common/quick-search name='nav-menu-quick-search'}}\n        </div>\n    {{/unless}}\n    <ul class=\"navPages-list{{#if theme_settings.navigation_design '!==' 'simple'}} navPages-list-depth-max{{/if}}\">\n        {{#unless theme_settings.epic-hide-category-navigation}}\n          {{#each categories}}\n              <li class=\"navPages-item navPages-item-category navPages-item-{{dashcase name}}\">\n              {{#if ../theme_settings.navigation_design '===' 'simple'}}\n                  {{> components/common/navigation-list}}\n              {{/if}}\n              {{#if ../theme_settings.navigation_design '===' 'alternate'}}\n                  {{> components/common/navigation-list-alternate}}\n              {{/if}}\n              </li>\n          {{/each}}\n        {{/unless}}\n        {{#unless theme_settings.hide_content_navigation}}\n            {{#each pages}}\n                 <li class=\"navPages-item navPages-item-page navPages-item-{{dashcase name}}\">\n                    {{#if ../theme_settings.navigation_design '===' 'simple'}}\n                        {{> components/common/navigation-list}}\n                    {{/if}}\n                    {{#if ../theme_settings.navigation_design '===' 'alternate'}}\n                        {{> components/common/navigation-list-alternate}}\n                    {{/if}}\n                 </li>\n             {{/each}}\n        {{/unless}}\n    </ul>\n    <ul class=\"navPages-list navPages-list--user\">\n        {{#if currency_selector.currencies.length '>' 1}}\n            <li class=\"navPages-item\">\n                <a class=\"navPages-action has-subMenu\"\n                   href=\"#\"\n                   data-collapsible=\"navPages-currency\"\n                   aria-controls=\"navPages-currency\"\n                   aria-expanded=\"false\"\n                   aria-label=\"{{lang 'common.currency' code=currency_selector.active_currency_code}}\"\n                >\n                    {{lang 'common.currency' code=currency_selector.active_currency_code}}\n                    <i class=\"icon navPages-action-moreIcon\" aria-hidden=\"true\">\n                        <svg>\n                            <use href=\"#icon-chevron-down\"></use>\n                        </svg>\n                    </i>\n                </a>\n                <div class=\"navPage-subMenu\" id=\"navPages-currency\" aria-hidden=\"true\" tabindex=\"-1\">\n                    <ul class=\"navPage-subMenu-list\">\n                        {{#each currency_selector.currencies}}\n                        <li class=\"navPage-subMenu-item\">\n                            <a class=\"navPage-subMenu-action navPages-action\"\n                               href=\"{{{switch_url}}}\"\n                               aria-label=\"{{name}}\"\n                               data-currency-code=\"{{{code}}}\"\n                               {{#if cart_currency_switch_url.length '>' 0 }}\n                               data-cart-currency-switch-url=\"{{{cart_currency_switch_url}}}\"\n                               {{/if}}\n                               data-warning=\"{{lang 'common.currency_switch_promotion'}}\"\n                            >\n                                {{#if is_active}}\n                                    <strong>{{name}}</strong>\n                                {{else}}\n                                    {{name}}\n                                {{/if}}\n                            </a>\n                        </li>\n                        {{/each}}\n                    </ul>\n                </div>\n            </li>\n        {{/if}}\n        {{#if theme_settings.show_channels}}\n            <li class=\"navPages-item\">\n                {{> components/common/channel-selector-mobile}}\n            </li>\n        {{/if}}\n        {{#if settings.gift_certificates_enabled}}\n            <li class=\"navPages-item\">\n                <a class=\"navPages-action\"\n                   href=\"{{urls.gift_certificate.purchase}}\"\n                   aria-label=\"{{lang 'common.gift_cert'}}\"\n                >\n                    {{lang 'common.gift_cert'}}\n                </a>\n            </li>\n        {{/if}}\n        {{#if customer.store_credit.value '>' 0}}\n            <li class=\"navPages-item\">\n                <a class=\"navPages-action navPages-action--storeCredit\">\n                    {{lang 'common.store_credit_overview' credit=customer.store_credit.formatted}}\n                </a>\n            </li>\n        {{/if}}\n        {{#if theme_settings.product_list_display_mode '==' 'list'}}\n            <li class=\"navPages-item\">\n                <a class=\"navPages-action navPages-action--compare\"\n                   href=\"{{urls.compare}}\"\n                   data-compare-nav\n                   aria-label=\"{{lang 'common.compare'}}\"\n                >\n                    {{lang 'common.compare'}}\n                    <span class=\"countPill countPill--positive countPill--alt\"></span>\n                </a>\n            </li>\n        {{/if}}\n        {{#if customer}}\n            <li class=\"navPages-item\">\n                <a class=\"navPages-action has-subMenu\"\n                   href=\"{{urls.account.index}}\"\n                   data-collapsible=\"navPages-account\"\n                   aria-label=\"{{lang 'common.account'}}\"\n                >\n                    {{lang 'common.account'}}\n                    <i class=\"icon navPages-action-moreIcon\" aria-hidden=\"true\">\n                        <svg><use href=\"#icon-chevron-down\" /></svg>\n                    </i>\n                </a>\n                <div class=\"navPage-subMenu\" id=\"navPages-account\" aria-hidden=\"true\" tabindex=\"-1\">\n                    <ul class=\"navPage-subMenu-list\">\n                        <li class=\"navPage-subMenu-item\">\n                            <a class=\"navPage-subMenu-action navPages-action\"\n                               href=\"{{urls.account.orders.all}}\"\n                               aria-label=\"{{lang 'account.nav.orders'}}\"\n                            >\n                                {{lang 'account.nav.orders'}}\n                            </a>\n                        </li>\n                        {{#if settings.returns_enabled}}\n                            <li class=\"navPage-subMenu-item\">\n                                <a class=\"navPage-subMenu-action navPages-action\"\n                                   href=\"{{urls.account.returns}}\"\n                                   aria-label=\"{{lang 'account.nav.returns'}}\"\n                                >\n                                    {{lang 'account.nav.returns'}}\n                                </a>\n                            </li>\n                        {{/if}}\n                        <li class=\"navPage-subMenu-item\">\n                            <a class=\"navPage-subMenu-action navPages-action\"\n                               href=\"{{urls.account.inbox}}\"\n                               aria-label=\"{{lang 'account.mobile_nav.messages'}}\"\n                            >\n                                {{lang 'account.mobile_nav.messages'}}\n                            </a>\n                        </li>\n                        <li class=\"navPage-subMenu-item\">\n                            <a class=\"navPage-subMenu-action navPages-action\"\n                               href=\"{{urls.account.addresses}}\"\n                               aria-label=\"{{lang 'account.nav.addresses'}}\"\n                            >\n                                {{lang 'account.nav.addresses'}}\n                            </a>\n                        </li>\n                        {{#if settings.show_payment_methods}}\n                            <li class=\"navPage-subMenu-item\">\n                                <a class=\"navPage-subMenu-action navPages-action\"\n                                   href=\"{{urls.account.payment_methods.all}}\"\n                                   aria-label=\"{{lang 'account.nav.payment_methods'}}\"\n                                >\n                                    {{lang 'account.nav.payment_methods'}}\n                                </a>\n                            </li>\n                        {{/if}}\n                        <li class=\"navPage-subMenu-item\">\n                            <a class=\"navPage-subMenu-action navPages-action\"\n                               href=\"{{urls.account.wishlists.all}}\"\n                               aria-label=\"{{lang 'account.mobile_nav.wishlists'}}\"\n                            >\n                                {{lang 'account.mobile_nav.wishlists'}}\n                            </a>\n                        </li>\n                        <li class=\"navPage-subMenu-item\">\n                            <a class=\"navPage-subMenu-action navPages-action\"\n                               href=\"{{urls.account.recent_items}}\"\n                               aria-label=\"{{lang 'account.nav.recently_viewed'}}\"\n                            >\n                                {{lang 'account.nav.recently_viewed'}}\n                            </a>\n                        </li>\n                        <li class=\"navPage-subMenu-item\">\n                            <a class=\"navPage-subMenu-action navPages-action\"\n                               href=\"{{urls.account.details}}\"\n                               aria-label=\"{{lang 'account.nav.settings'}}\"\n                            >\n                                {{lang 'account.nav.settings'}}\n                            </a>\n                        </li>\n                    </ul>\n                </div>\n            </li>\n            <li class=\"navPages-item\">\n                <a class=\"navPages-action\"\n                   href=\"{{urls.auth.logout}}\"\n                   aria-label=\"{{lang 'common.logout'}}\"\n                >\n                    {{lang 'common.logout'}}\n                </a>\n            </li>\n        {{else}}\n            <li class=\"navPages-item\">\n                <a class=\"navPages-action\"\n                   href=\"{{urls.auth.login}}\"\n                   aria-label=\"{{lang 'common.login'}}\"\n                >\n                    {{lang 'common.login'}}\n                </a>\n                {{#if settings.account_creation_enabled}}\n                    {{lang 'common.or'}}\n                    <a class=\"navPages-action\"\n                       href=\"{{urls.auth.create_account}}\"\n                       aria-label=\"{{lang 'common.sign_up'}}\"\n                    >\n                        {{lang 'common.sign_up'}}\n                    </a>\n                {{/if}}\n            </li>\n        {{/if}}\n        {{#if theme_settings.social_icon_placement_top}}\n            <li class=\"navPages-item\">\n                {{> components/common/social-links}}\n            </li>\n        {{/if}}\n    </ul>\n</nav>\n",
  "components/common/channel-selector": "{{#if theme_settings.channels.length '>' 1}}\n<ul class=\"navUser-section\">\n    <li class=\"navUser-item\">\n        <a href=\"#\"\n           class=\"navUser-action navUser-action--channelSelector has-dropdown\"\n           data-dropdown=\"channelSelection\"\n           aria-controls=\"channelSelection\"\n           aria-expanded=\"false\"\n        >\n            {{#each theme_settings.channels}}\n                {{#if is_active}}\n                    {{lang 'common.channel' code=code}}\n                {{/if}}\n            {{/each}}\n            <i class=\"icon\" aria-hidden=\"true\">\n                <svg>\n                    <use href=\"#icon-chevron-down\"/>\n                </svg>\n            </i>\n        </a>\n        <ul class=\"dropdown-menu\" id=\"channelSelection\" data-dropdown-content aria-hidden=\"true\" tabindex=\"-1\">\n            {{#each theme_settings.channels}}\n                <li class=\"dropdown-menu-item\">\n                    <a href=\"{{{switch_url}}}\" data-channel-code=\"{{{code}}}\" data-warning=\"{{lang 'common.channel_switch_warning'}}\">\n                        {{#if is_active}}\n                            <strong>{{name}}</strong>\n                        {{else}}\n                            {{name}}\n                        {{/if}}\n                    </a>\n                </li>\n            {{/each}}\n        </ul>\n    </li>\n</ul>\n{{/if}}\n",
  "components/common/currency-selector": "{{#if currency_selector.currencies.length '>' 1}}\n<ul class=\"navUser-section\">\n    <li class=\"navUser-item\">\n        <a class=\"navUser-action navUser-action--currencySelector has-dropdown\"\n           href=\"#\"\n           data-dropdown=\"currencySelection\"\n           aria-controls=\"currencySelection\"\n           aria-expanded=\"false\"\n        >\n            {{lang 'common.currency' code=currency_selector.active_currency_code}}\n            <i class=\"icon\" aria-hidden=\"true\">\n                <svg>\n                    <use href=\"#icon-chevron-down\" />\n                </svg>\n            </i>\n        </a>\n        <ul class=\"dropdown-menu\" id=\"currencySelection\" data-dropdown-content aria-hidden=\"true\" tabindex=\"-1\">\n            {{#each currency_selector.currencies}}\n            <li class=\"dropdown-menu-item\">\n                <a href=\"{{{switch_url}}}\"\n                   data-currency-code=\"{{{code}}}\"\n                   {{#if cart_currency_switch_url.length '>' 0 }}\n                   data-cart-currency-switch-url=\"{{{cart_currency_switch_url}}}\"\n                   {{/if}}\n                   data-warning=\"{{lang 'common.currency_switch_promotion'}}\"\n                >\n                {{#if is_active}}\n                    <strong>{{name}}</strong>\n                {{else}}\n                    {{name}}\n                {{/if}}\n                </a>\n            </li>\n            {{/each}}\n        </ul>\n    </li>\n</ul>\n{{/if}}\n",
  "components/common/navigation-list": "{{#if children}}\n<a class=\"navPages-action has-subMenu{{#if is_active}} activePage{{/if}}\"\n   href=\"{{url}}\"\n   data-collapsible=\"navPages-{{#if id}}{{id}}{{else}}{{dashcase name}}{{/if}}\"\n>\n    {{name}}\n    <i class=\"icon navPages-action-moreIcon\" aria-hidden=\"true\">\n        <svg><use href=\"#icon-chevron-down\" /></svg>\n    </i>\n</a>\n<div class=\"navPage-subMenu\" id=\"navPages-{{#if id}}{{id}}{{else}}{{dashcase name}}{{/if}}\" aria-hidden=\"true\" tabindex=\"-1\">\n    <ul class=\"navPage-subMenu-list\">\n        <li class=\"navPage-subMenu-item only-mobile\">\n            <a class=\"navPage-subMenu-action navPages-action\"\n               href=\"{{url}}\"\n               aria-label=\"{{lang 'category.view_all.name' category=name}}\"\n            >\n                {{lang 'category.view_all.name' category=name}}\n            </a>\n        </li>\n        {{#each children}}\n            <li class=\"navPage-subMenu-item\">\n                {{#if children}}\n                    <a class=\"navPage-subMenu-action navPages-action has-subMenu{{#if is_active}} activePage{{/if}}\"\n                       href=\"{{url}}\"\n                       aria-label=\"{{name}}\"\n                    >\n                        {{name}}\n                        <span class=\"collapsible-icon-wrapper\"\n                            data-collapsible=\"navPages-{{id}}\"\n                            data-collapsible-disabled-breakpoint=\"medium\"\n                            data-collapsible-disabled-state=\"open\"\n                            data-collapsible-enabled-state=\"closed\"\n                        >\n                            <i class=\"icon navPages-action-moreIcon\" aria-hidden=\"true\">\n                                <svg><use href=\"#icon-chevron-down\" /></svg>\n                            </i>\n                        </span>\n                    </a>\n                    <ul class=\"navPage-childList\" id=\"navPages-{{id}}\">\n                        {{#each children}}\n                        <li class=\"navPage-childList-item\">\n                            <a class=\"navPage-childList-action navPages-action{{#if is_active}} activePage{{/if}}\"\n                               href=\"{{url}}\"\n                               aria-label=\"{{name}}\"\n                            >\n                                {{name}}\n                            </a>\n                        </li>\n                        {{/each}}\n                    </ul>\n                {{else}}\n                    <a class=\"navPage-subMenu-action navPages-action{{#if is_active}} activePage{{/if}}\"\n                       href=\"{{url}}\"\n                       aria-label=\"{{name}}\"\n                    >\n                        {{name}}\n                    </a>\n                {{/if}}\n            </li>\n        {{/each}}\n    </ul>\n</div>\n{{else}}\n<a class=\"navPages-action{{#if is_active}} activePage{{/if}}\"\n   href=\"{{url}}\"\n   aria-label=\"{{name}}\"\n>\n    {{name}}\n</a>\n{{/if}}\n",
  "components/common/navigation-list-alternate": "{{#if children}}\n    <a class=\"navPages-action navPages-action-depth-max has-subMenu is-root{{#if is_active}} activePage{{/if}}\"\n       href=\"{{url}}\"\n       data-collapsible=\"navPages-{{#if id}}{{id}}{{else}}{{dashcase name}}{{/if}}\"\n       aria-label=\"{{name}}\"\n    >\n        {{name}}\n        <i class=\"icon navPages-action-moreIcon\" aria-hidden=\"true\">\n            <svg><use href=\"#icon-chevron-down\" /></svg>\n        </i>\n    </a>\n    {{> components/common/navigation-dropdown}}\n{{else}}\n    <a class=\"navPages-action{{#if is_active}} activePage{{/if}}\"\n       href=\"{{url}}\"\n       aria-label=\"{{name}}\"\n    >\n        {{name}}\n    </a>\n{{/if}}\n",
  "components/common/channel-selector-mobile": "{{#if theme_settings.channels.length '>' 1}}\n<a href=\"#\"\n   class=\"navPages-action has-subMenu\"\n   data-collapsible=\"navPages-channel\"\n   aria-controls=\"navPages-channel\"\n   aria-expanded=\"false\"\n   aria-label=\"\n    {{#each theme_settings.channels}}\n        {{#if is_active}}\n            {{lang 'common.channel' code=code}}\n        {{/if}}\n    {{/each}}\n   \"\n>\n    {{#each theme_settings.channels}}\n        {{#if is_active}}\n            {{lang 'common.channel' code=code}}\n        {{/if}}\n    {{/each}}\n    <i class=\"icon navPages-action-moreIcon\" aria-hidden=\"true\">\n        <svg>\n            <use href=\"#icon-chevron-down\"></use>\n        </svg>\n    </i>\n</a>\n<div class=\"navPage-subMenu\" id=\"navPages-channel\" aria-hidden=\"true\" tabindex=\"-1\">\n    <ul class=\"navPage-subMenu-list\">\n        {{#each theme_settings.channels}}\n        <li class=\"navPage-subMenu-item\">\n            <a href=\"{{{switch_url}}}\"\n               class=\"navPage-subMenu-action navPages-action\"\n               aria-label=\"{{name}}\"\n               data-channel-code=\"{{{code}}}\"\n               data-warning=\"{{lang 'common.channel_switch_warning'}}\"\n            >\n                {{name}}\n            </a>\n        </li>\n        {{/each}}\n    </ul>\n</div>\n{{/if}}\n",
  "components/common/social-links": "{{#if social_media}}\n    <ul class=\"socialLinks socialLinks--alt\">\n        {{#each social_media}}\n            {{#if display_name '===' 'twitter'}}\n                <li class=\"socialLinks-item\">\n                    <a class=\"icon icon--x\"\n                    href=\"{{url}}\"\n                    target=\"_blank\"\n                    rel=\"noopener\"\n                    title=\"X\"\n                    >\n                        <span class=\"aria-description--hidden\">X</span>\n                        <svg>\n                            <use href=\"#icon-x\"/>\n                        </svg>\n                    </a>\n                </li>\n            {{else}}\n                {{#and (if display_name '===' 'tumblr') (if ../theme_settings.epic-toggle-tiktok-icon)}}\n                  <li class=\"socialLinks-item\">\n                    <a class=\"icon icon--tiktok\"\n                    href=\"{{url}}\"\n                    target=\"_blank\"\n                    rel=\"noopener\"\n                    title=\"TikTok\"\n                    >\n                        <span class=\"aria-description--hidden\">TikTok</span>\n                        <svg>\n                            <use href=\"#icon-tiktok\"/>\n                        </svg>\n                    </a>\n                  </li>\n                {{else}}\n                  <li class=\"socialLinks-item\">\n                    <a class=\"icon icon--{{display_name}}\"\n                    href=\"{{url}}\"\n                    target=\"_blank\"\n                    rel=\"noopener\"\n                    title=\"{{{capitalize display_name}}}\"\n                    >\n                        <span class=\"aria-description--hidden\">{{{capitalize display_name}}}</span>\n                        <svg>\n                            <use href=\"#icon-{{display_name}}\"/>\n                        </svg>\n                    </a>\n                  </li>\n                {{/and}}\n            {{/if}}\n        {{/each}}\n    </ul>\n{{/if}}\n",
  "components/common/navigation-dropdown": "<div class=\"navPage-subMenu navPage-subMenu-horizontal\" id=\"navPages-{{#if id}}{{id}}{{else}}{{dashcase name}}{{/if}}\" aria-hidden=\"true\" tabindex=\"-1\">\n    <ul class=\"navPage-subMenu-list\">\n        {{#if id}}\n        <li class=\"navPage-subMenu-item-parent\">\n            <a class=\"navPage-subMenu-action navPages-action navPages-action-depth-max\" href=\"{{url}}\">{{lang 'category.view_all.name' category=name}}</a>\n        </li>\n        {{/if}}\n        {{#each children}}\n            <li class=\"navPage-subMenu-item-child\">\n                {{#if children}}\n                    <a class=\"navPage-subMenu-action navPages-action navPages-action-depth-max has-subMenu{{#if is_active}} activePage{{/if}}\" href=\"{{url}}\" data-collapsible=\"navPages-{{id}}\">\n                        {{name}}<i class=\"icon navPages-action-moreIcon\" aria-hidden=\"true\"><svg><use href=\"#icon-chevron-down\" /></svg></i>\n                    </a>\n                    {{> components/common/navigation-dropdown}}\n                {{else}}\n                    <a class=\"navPage-subMenu-action navPages-action{{#if is_active}} activePage{{/if}}\" href=\"{{url}}\">{{name}}</a>\n                {{/if}}\n            </li>\n        {{/each}}\n    </ul>\n</div>\n"
}